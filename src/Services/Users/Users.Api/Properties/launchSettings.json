    "https": {
      "commandName": "Project",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "POSTGRES_HOST": "localhost",
        "POSTGRES_PORT": "5432",
		"POSTGRES_DATABASE": "usersDb",
		"POSTGRES_USER": "postgres",
		"POSTGRES_PASSWORD": "postgres"
