{
  "profiles": {
    "http": {
      "commandName": "Project",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "USERS_MICROSERVICE_HOST": "localhost",
        "USERS_MICROSERVICE_PORT": "7020",
        "PRODUCTS_MICROSERVICE_HOST": "localhost",
        "PRODUCTS_MICROSERVICE_PORT": "7201"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "http://localhost:5243"
    },
    "https": {
      "commandName": "Project",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "USERS_MICROSERVICE_HOST": "localhost",
        "USERS_MICROSERVICE_PORT": "7020",
        "PRODUCTS_MICROSERVICE_HOST": "localhost",
        "PRODUCTS_MICROSERVICE_PORT": "7201"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "https://localhost:7210;http://localhost:5243"
